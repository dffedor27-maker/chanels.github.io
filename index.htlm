    <script type="text/javascript">
        function goToChannel() {
            // Ваша новая ссылка на канал в MAX
            var url = 'https://max.ru/id343530079380_biz/AZ6HIdVOQB8';
            var done = false;
            var goalsSent = 0;

            function checkAndGo() {
                goalsSent++;
                if (goalsSent === 2 && !done) {
                    done = true;
                    location.href = url;
                }
            }

            function fallbackGo() {
                if (!done) {
                    done = true;
                    location.href = url;
                }
            }

            // Отправка двух целей в ваш счётчик
            ym(109721884, 'reachGoal', 'userDidSubscribe', checkAndGo);
            ym(109721884, 'reachGoal', 'toChannel', checkAndGo);

            // Резервный переход через 1.5 секунды
            setTimeout(fallbackGo, 1500);
        }
    </script>
